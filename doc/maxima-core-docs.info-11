     (%i20) usedimension(N);
     Done.  To have Maxima simplify to this dimension, use
     setunits([unit]) to select a unit.
     (%o20)                               true
     
     
     (%i21) usedimension(J);
     Done.  To have Maxima simplify to this dimension, use
     setunits([unit]) to select a unit.
     (%o21)                               true
     
     
