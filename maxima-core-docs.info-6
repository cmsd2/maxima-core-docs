 -- Function: poly_multiply (POLY1, POLY2, VARLIST)
     Returns the product of polynomials _poly1_ and _poly2_.

     (%i2) poly_multiply(z+x^2*y,x-z,[x,y,z])-(z+x^2*y)*(x-z),expand;
     (%o1)                                  0


